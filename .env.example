# API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Model ID (required)
MODEL_ID=claude-sonnet-4-6

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# LLM Provider (optional, defaults to anthropic)
# Set to "deepseek" to use DeepSeek API
# LLM_PROVIDER=anthropic

# DeepSeek API Key (optional)
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxx

# DeepSeek Base URL (optional, defaults to https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek Model ID (optional, defaults to deepseek-chat)
# DEEPSEEK_MODEL_ID=deepseek-chat
